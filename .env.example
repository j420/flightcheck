# Amadeus Flight Offers API — for seat availability checking
# Sign up free at: https://developers.amadeus.com
# Free tier: 2,000 API calls/month (sufficient for this tool)
#
# 1. Create an account at developers.amadeus.com
# 2. Create a new app (Self-Service > My Apps > Create)
# 3. Copy API Key and API Secret below
# 4. For production data, request Production access in the dashboard
#
# Without these keys the app works normally but cannot check seat availability.

AMADEUS_API_KEY=your_api_key_here
AMADEUS_API_SECRET=your_api_secret_here

# Use test API for development (returns simulated data)
# AMADEUS_BASE_URL=https://test.api.amadeus.com

# Use production API for real availability data (default)
# AMADEUS_BASE_URL=https://api.amadeus.com
